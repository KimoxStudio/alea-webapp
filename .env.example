# ============================================================
# SUPABASE
# Dashboard: supabase.com → your project → Project Settings → API
# ============================================================

# Project URL
# Location: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key — safe to expose in the browser
# Format: sb_publishable_xxxxxxxx
# Location: Project Settings → API → Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Secret key — SERVER ONLY, never expose to the browser
# Format: sb_secret_xxxxxxxx
# Location: Project Settings → API Keys → Secret keys → default
SUPABASE_SECRET_DEFAULT_KEY=sb_secret_xxxxxxxxxxxxxxxx

# ============================================================
# AUTH.JS (NextAuth v5) — F1 migration scaffolding, not yet in use
# See Linear KIM-393..422, Supabase→Neon migration (F1). Parallel to the live
# Supabase Auth flow above; nothing in the app reads these yet.
# ============================================================

# Keeps `/api/authjs/*` returning 404 until explicitly set to "true". This is
# a safety gate, not a launch switch: leave unset in every environment until
# the KIM-419/420 cutover wires this route behind the same rate limiting as
# `/api/auth/login` — do not set to "true" just because AUTH_SECRET/POSTGRES_URL
# are configured.
AUTH_JS_ENABLED=false

# Secret used to sign/encrypt Auth.js JWTs and cookies. Generate with:
# openssl rand -base64 32
AUTH_SECRET=your-random-auth-secret

# Target Postgres (Neon / Vercel Postgres) connection string, used by the
# Auth.js Credentials provider to look up `profiles.password_hash`.
# Pooled connection string (e.g. Vercel Postgres "POSTGRES_URL").
POSTGRES_URL=

# Direct/non-pooled connection string to the same database. Optional —
# only needed for operations that must bypass the connection pooler.
POSTGRES_URL_NON_POOLING=

# ============================================================
# APPLICATION
# ============================================================

# Base URL of the app (used for auth callbacks and redirects).
# Previously also drove cookie Secure flag — that role is now taken by COOKIE_SECURE below.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Controls the `Secure` flag on auth and CSRF cookies. Evaluated at RUNTIME (not build time),
# so the same build artifact works correctly on both HTTP staging and HTTPS production.
# Set to `true` on any deployment that is served over HTTPS.
# If unset, defaults to `true` when NODE_ENV=production and `false` otherwise — leave this
# unset in production so a deployed HTTPS environment never accidentally ships insecure cookies.
# For local HTTP dev only, uncomment the next line:
# COOKIE_SECURE=false

# Enable this only when the deployment ingress strips and rewrites both `x-real-ip`
# and `x-forwarded-for` before requests reach the app runtime.
TRUST_PROXY_HEADERS=false

# Comma-separated CIDR allowlist for reverse proxies that are permitted to supply `x-forwarded-for`.
# Only requests arriving from one of these source IP ranges will trust the first forwarded address for rate limiting,
# and only when TRUST_PROXY_HEADERS=true. Everything else falls back to `x-real-ip` (or `local` if unavailable).
# Set this explicitly in deployed environments, and ensure your ingress strips and overwrites inbound `x-real-ip`
# and `x-forwarded-for`.
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Optional API base URL override for the frontend.
# If unset, the runtime defaults to `/api`.
# Only set this when the browser should call a different API base URL.
NEXT_PUBLIC_API_URL=/api

# External URL for the association link in the footer
NEXT_PUBLIC_ASSOCIATION_URL=

# Club timezone override (IANA name, e.g. Atlantic/Canary).
# Defaults to the server's system timezone if not set.
# CLUB_TIMEZONE=

# ============================================================
# RATE LIMITING (optional — shared store via Upstash Redis)
# ============================================================

# When both variables are set, the rate limiter uses Upstash Redis (sliding-window,
# shared across all serverless instances). Without them, an in-memory Map is used
# (per-instance only — fine for local dev and tests, but bypassable in production
# by rotating instances).
# Dashboard: console.upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# CRON
# ============================================================

# Secret used to authenticate requests from the external cron scheduler.
# Set this to a long random string — e.g. openssl rand -hex 32
# In cron-job.org: add request header  Authorization: Bearer <value>
# The route POST /api/cron/cancel-pending will return 401 if this header is missing or wrong.
CRON_SECRET=your-random-cron-secret
